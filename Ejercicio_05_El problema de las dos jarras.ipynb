   ],
   "source": [
    "import Data.List (sortOn)\n",
    "\n",
    "--Inicio\n",
    "type Estado = (Int, Int)\n",
    "type Nodo = Estado\n",
    "type Costo = Int\n",
    "type Grafo = [(Nodo, [(Nodo, Costo)])]\n",
    "\n",
    "capA, capB :: Int\n",
    "capA = 5\n",
    "capB = 3\n",
    "\n",
    "\n",
    "--- Codigo aplicado\n",
    "-- Verter de A → B\n",
    "transferirAB :: Estado -> Estado\n",
    "transferirAB (a, b) =\n",
    "  let capacidadDisponibleB = capB - b\n",
    "      cantidadTransferida = min a capacidadDisponibleB\n",
    "  in (a - cantidadTransferida, b + cantidadTransferida)\n",
    "\n",
    "-- Verter de B → A\n",
    "transferirBA :: Estado -> Estado\n",
    "transferirBA (a, b) =\n",
    "  let capacidadDisponibleA = capA - a\n",
    "      cantidadTransferida = min b capacidadDisponibleA\n",
    "  in (a + cantidadTransferida, b - cantidadTransferida)\n",
    "\n",
    "-- Genera todos los estados alcanzables desde uno dado\n",
    "vecinos :: Estado -> [(Estado, Costo)]\n",
    "vecinos (a,b) =\n",
    "  [ ((capA, b), 1)            -- Llenar jarra A\n",
    "  , ((a, capB), 1)            -- Llenar jarra B\n",
    "  , ((0, b), 1)               -- Vaciar jarra A\n",
    "  , ((a, 0), 1)               -- Vaciar jarra B\n",
    "  , (transferirAB (a,b), 1)  -- Verter A→B\n",
    "  , (transferirBA (a,b), 1)  -- Verter B→A\n",
    "  ]\n",
    "\n",
    "--- Codigo aplicado\n",
    "-- Heurística \n",
    "heuristica :: Estado -> Costo\n",
    "heuristica (a, _) = abs (4 - a)\n",
    "\n",
    "--Probar la solución con el algoritmo base de A*\n",
    "aStar :: (Nodo -> [(Nodo, Costo)]) -> (Nodo -> Costo) -> Nodo -> Nodo -> [(Nodo, Costo)]\n",
    "aStar sucesores heuristica inicio meta = buscar [(inicio, 0)] []\n",
    "  where\n",
    "    buscar [] _ = []\n",
    "    buscar ((nodo, costo):cola) visitados\n",
    "      | nodo == meta = [(nodo, costo)]\n",
    "      | nodo `elem` visitados = buscar cola visitados\n",
    "      | otherwise =\n",
    "          let nuevos = [ (v, costo + c) \n",
    "                       | (v, c) <- sucesores nodo\n",
    "                       , v `notElem` visitados\n",
    "                       ]\n",
    "              ordenados = sortOn (\\(v, c) -> c + heuristica v) (cola ++ nuevos)\n",
    "          in (nodo, costo) : buscar ordenados (nodo : visitados)\n",
    "\n",
    "\n",
    "---Editado \n",
    "--Ejecución\n",
    "inicio :: Estado\n",
    "inicio = (0,0)\n",
    "\n",
    "meta :: Estado\n",
    "meta = (4,0)\n",
    "\n",
    "solucion :: [(Estado, Costo)]\n",
    "solucion = aStar vecinos heuristica inicio meta\n",
    "aStar vecinos heuristica inicio meta\n",
    "\n",
    "--PRUEBAS
    "main :: IO ()\n",
    "main = do\n",
    "  putStrLn \"Solución encontrada:\"\n",
    "  mapM_ print solucion"
   ]
